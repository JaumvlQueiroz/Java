        "import os\n",
        "import pandas as pd\n",
        "from google.colab import files\n",
        "\n",
        "# ==========================================\n",
        "# 0. LIMPEZA (Reset do ambiente)\n",
        "# ==========================================\n",
        "print(\"🧹 Limpando ambiente...\")\n",
        "for f in os.listdir('.'):\n",
        "    if f.lower().endswith('.csv'):\n",
        "        os.remove(f)\n",
        "\n",
        "# ==========================================\n",
        "# 1. UPLOAD (Selecione as planilhas originais)\n",
        "# ==========================================\n",
        "print(\"\\n⬇️ Passo 1: Selecione as planilhas originais...\")\n",
        "uploaded = files.upload()\n",
        "\n",
        "# ==========================================\n",
        "# 2. PROCESSAMENTO E FILTRO DE LINHAS FANTASMAS\n",
        "# ==========================================\n",
        "print(\"\\n⚙️ Passo 2: Gerando formato final...\")\n",
        "\n",
        "arquivos = sorted([f for f in os.listdir('.') if f.lower().endswith('.csv')])\n",
        "\n",
        "for f in arquivos:\n",
        "    try:\n",
        "        # Extrai data e converte para número (para tirar o zero do mês, ex: \"03\" vira 3)\n",
        "        partes = f.split('.')\n",
        "        if len(partes) > 6:\n",
        "            data_str = partes[6]\n",
        "            ano_val = int(data_str[:4])\n",
        "            mes_val = int(data_str[4:])\n",
        "        else:\n",
        "            ano_val, mes_val = 0, 0\n",
        "\n",
        "        # Lê a planilha\n",
        "        df = pd.read_csv(f, sep=';', decimal=',', thousands='.')\n",
        "\n",
        "        # 🚨 SOLUÇÃO DO BUG DAS LINHAS EXTRAS:\n",
        "        # Deleta qualquer linha onde o município esteja vazio/nulo (remove lixo do rodapé)\n",
        "        df = df.dropna(subset=['NU_MUNICIPIO_IBGE'])\n",
        "\n",
        "        # Cria a nova planilha exatamente no modelo que você enviou\n",
        "        df_final = pd.DataFrame()\n",
        "\n",
        "        # Converte o código IBGE para número inteiro (remove eventuais decimais .0)\n",
        "        df_final['codigo'] = df['NU_MUNICIPIO_IBGE'].astype(int)\n",
        "        df_final['mes'] = mes_val\n",
        "        df_final['ano'] = ano_val\n",
        "\n",
        "        # Mantém as variáveis solicitadas na imagem\n",
        "        df_final['V1516'] = df['TOTAL_FAMILIAS_BENEFICIARIAS']\n",
        "        df_final['V1517'] = df['TOTAL_PESSOAS']\n",
        "        df_final['V1518'] = df['TOTAL_MULHERES_RF']\n",
        "        df_final['V1519'] = df['VALOR_VALE']\n",
        "        df_final['V1520'] = df['TOTAL_VALES']\n",
        "        df_final['V1521'] = df['VALOR_TOTAL_FOLHA']\n",
        "\n",
        "        # Salva o arquivo no formato perfeito\n",
        "        nome_saida = f\"CARGA_{f}\"\n",
        "        df_final.to_csv(nome_saida, sep=';', decimal=',', float_format='%.2f', index=False)\n",
        "\n",
        "        print(f\"✅ Sucesso: {nome_saida} | Linhas reais válidas: {len(df_final)}\")\n",
        "\n",
        "    except Exception as e:\n",
        "        print(f\"❌ Erro ao processar {f}: {e}\")\n",
        "\n",
        "# ==========================================\n",
        "# 3. DOWNLOAD\n",
        "# ==========================================\n",
        "print(\"\\n💾 Passo 3: Baixando arquivos prontos...\")\n",
        "for f in sorted(os.listdir('.')):\n",
        "    if f.startswith('CARGA_'):\n",
        "        files.download(f)\n",
        "\n",
        "print(\"\\n🙌 Tudo pronto! O arquivo gerado estará igual ao modelo (codigo;mes;ano;V...) e sem as linhas vazias.\")"
      ],
