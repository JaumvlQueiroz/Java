        "\n",
        "# ==========================================\n",
        "# 2. AUDITORIA E COMPARAÇÃO INTELIGENTE\n",
        "# ==========================================\n",
        "print(\"\\n⚙️ Passo 2: Cruzando os dados e validando...\\n\")\n",
        "\n",
        "arquivos_carga = [f for f in os.listdir('.') if f.startswith('CARGA_')]\n",
        "arquivos_originais = [f for f in os.listdir('.') if f.lower().endswith('.csv') and not f.startswith('CARGA_')]\n",
        "\n",
        "# Função para limpar os nomes e facilitar o cruzamento\n",
        "def limpar_nome_para_busca(nome):\n",
        "    nome = nome.lower() # Tudo minúsculo\n",
        "    nome = nome.replace('carga_', '') # Tira o prefixo\n",
        "    nome = re.sub(r'\\s*\\(\\d+\\)', '', nome) # Apaga os \" (1)\", \" (2)\" que o Windows coloca\n",
        "    return nome\n",
        "\n",
        "# Cria um \"dicionário\" mapeando o nome limpo para o nome real do arquivo original\n",
        "dict_originais = {limpar_nome_para_busca(f): f for f in arquivos_originais}\n",
        "\n",
        "if not arquivos_carga or not arquivos_originais:\n",
        "    print(\"❌ ATENÇÃO: Você precisa subir os arquivos ORIGINAIS e os arquivos CARGA para comparar.\")\n",
        "else:\n",
        "    for arq_carga in arquivos_carga:\n",
        "        chave_busca_carga = limpar_nome_para_busca(arq_carga)\n",
        "\n",
        "        # Verifica se o arquivo carga tem um par correspondente nos originais\n",
        "        if chave_busca_carga in dict_originais:\n",
        "            arq_original = dict_originais[chave_busca_carga]\n",
        "            print(f\"🔍 Auditando par:\\n   Original: {arq_original}\\n   Carga:    {arq_carga}\")\n",
        "\n",
        "            try:\n",
        "                # Lê os dois arquivos\n",
        "                df_orig = pd.read_csv(arq_original, sep=';', decimal=',', thousands='.')\n",
        "                df_carg = pd.read_csv(arq_carga, sep=';', decimal=',')\n",
        "\n",
        "                # Prepara o original (tira linhas vazias do IBGE para bater com a carga)\n",
        "                df_orig = df_orig.dropna(subset=['NU_MUNICIPIO_IBGE']).copy()\n",
        "                df_orig['NU_MUNICIPIO_IBGE'] = df_orig['NU_MUNICIPIO_IBGE'].astype(int)\n",
        "\n",
        "                df_carg['codigo'] = df_carg['codigo'].astype(int)\n",
        "\n",
        "                # --- VERIFICAÇÃO 1: QUANTIDADE DE LINHAS ---\n",
        "                linhas_orig = len(df_orig)\n",
        "                linhas_carg = len(df_carg)\n",
        "                if linhas_orig == linhas_carg:\n",
        "                    print(f\"   ✔️ Linhas OK: Ambos têm {linhas_orig} registros.\")\n",
        "                else:\n",
        "                    print(f\"   ❌ ERRO NAS LINHAS: Original tem {linhas_orig}, Carga tem {linhas_carg}.\")\n",
        "\n",
        "                # --- VERIFICAÇÃO 2: TOTAIS FINANCEIROS ---\n",
        "                total_orig = df_orig['VALOR_TOTAL_FOLHA'].sum().round(2)\n",
        "                total_carg = df_carg['V1521'].sum().round(2)\n",
        "                if total_orig == total_carg:\n",
        "                    print(f\"   ✔️ Financeiro OK: Total da folha bate em R$ {total_orig:,.2f}\")\n",
        "                else:\n",
        "                    print(f\"   ❌ ERRO FINANCEIRO: Original R$ {total_orig:,.2f} | Carga R$ {total_carg:,.2f}\")\n",
        "\n",
        "                # --- VERIFICAÇÃO 3: CRUZAMENTO COLUNA A COLUNA ---\n",
        "                comparacao = {\n",
        "                    'TOTAL_FAMILIAS_BENEFICIARIAS': 'V1516',\n",
        "                    'TOTAL_PESSOAS': 'V1517',\n",
        "                    'TOTAL_MULHERES_RF': 'V1518',\n",
        "                    'VALOR_VALE': 'V1519',\n",
        "                    'TOTAL_VALES': 'V1520'\n",
        "                }\n",
        "\n",
        "                # Junta as duas tabelas usando o código IBGE\n",
        "                df_merge = pd.merge(df_orig, df_carg, left_on='NU_MUNICIPIO_IBGE', right_on='codigo')\n",
        "\n",
        "                erros_encontrados = 0\n",
        "                for col_orig, col_carg in comparacao.items():\n",
        "                    divergentes = df_merge[df_merge[col_orig].round(2) != df_merge[col_carg].round(2)]\n",
        "                    if len(divergentes) > 0:\n",
        "                        erros_encontrados += len(divergentes)\n",
        "                        print(f\"   ❌ DIVERGÊNCIA em {col_orig} vs {col_carg} ({len(divergentes)} registros errados)\")\n",
        "\n",
        "                if erros_encontrados == 0:\n",
        "                    print(\"   ✔️ Dados consistentes: Todas as variáveis V1516 a V1520 batem perfeitamente!\")\n",
        "\n",
        "                print(\"-\" * 50)\n",
        "\n",
        "            except Exception as e:\n",
        "                print(f\"   ❌ Erro na leitura/comparação deste par: {e}\")\n",
        "                print(\"-\" * 50)\n",
        "        else:\n",
        "            print(f\"⚠️ Aviso: O arquivo original equivalente a {arq_carga} não foi encontrado.\")\n",
        "            print(\"-\" * 50)\n",
        "\n",
        "print(\"\\n🙌 Processo de validação concluído!\")"
