        "# 0. LIMPEZA\n",
        "# ==========================================\n",
        "print(\"🧹 Limpando ambiente para a validação...\")\n",
        "for f in os.listdir('.'):\n",
        "    if f.lower().endswith('.csv'):\n",
        "        os.remove(f)\n",
        "\n",
        "# ==========================================\n",
        "# 1. UPLOAD DOS DOIS ARQUIVOS\n",
        "# ==========================================\n",
        "print(\"\\n⬇️ Passo 1: Faça o upload dos 5 originais e das 5 CARGAS juntos (10 arquivos)...\")\n",
